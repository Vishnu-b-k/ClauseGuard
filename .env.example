# Runtime environment: development, test, staging, or production.
APP_ENV=development

# Local demo mode. Production-like environments reject true.
MOCK_MODE=true

# Comma-separated frontend origins. Do not use * outside local development.
CORS_ALLOW_ORIGINS=http://localhost:3000

# Ingestion limits.
MAX_UPLOAD_SIZE_BYTES=26214400
UPLOAD_CHUNK_SIZE_BYTES=1048576

# Pipeline controls.
RETRIEVAL_TOP_K=5
CONFIDENCE_THRESHOLD=0.8

# API operations.
LOG_LEVEL=INFO
ENABLE_API_DOCS=true